# Database Settings
# For PostgreSQL later: postgresql://user:password@localhost/pitchup
DATABASE_URL=sqlite:///./pitchup.db

# Authentication (JWT) Settings
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Email Provider Settings (Resend)
# Leave blank to log magic links to terminal console for local testing
RESEND_API_KEY=

# Application URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
